# ============================================================
# RCMLight Backend — zmienne środowiskowe
# Skopiuj ten plik do .env i uzupełnij wartości
# ============================================================

# Środowisko
NODE_ENV=development
PORT=3001

# Baza danych PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/rcmlight_db?schema=public"

# JWT — sekrety (min. 32 znaki losowych)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# Czas życia tokenów
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — adresy frontendów oddzielone przecinkiem
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting (żądania na okno czasowe)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# Logowanie
LOG_LEVEL=debug
